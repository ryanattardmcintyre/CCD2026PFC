@model IEnumerable<WebApplication2.Models.FirestoreModels.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="container">
    <h1 class="my-4">Events</h1>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">No events found.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var evt in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(evt?.Poster))
                        {
                            <img src="@evt.Poster" class="card-img-top" alt="Poster for @evt.Name" style="object-fit:cover; height:200px; width:100%;" />
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/600x200?text=No+Image" class="card-img-top" alt="No poster available" style="object-fit:cover; height:200px; width:100%;" />
                        }

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@evt.Name</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@evt.Date.ToString("MMM d, yyyy h:mm tt")</h6>
                            <p class="card-text">@evt.Description</p>

                            <ul class="list-unstyled mt-auto">
                                <li><strong>Location:</strong> @evt.Location</li>
                                <li><strong>Price:</strong> @((evt.Price == 0) ? "Free" : evt.Price.ToString("C"))</li>
                            </ul>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="d-flex gap-2 align-items-center">
                                @if (!string.IsNullOrEmpty(evt?.GuestList))
                                {
                                    <a href="@evt.GuestList" class="btn btn-sm btn-outline-secondary" download>Download Guest List</a>
                                }

                                <form method="post" action="/Tickets/Buy" class="d-flex align-items-center gap-2 m-0">
                                    <label class="mb-0">Quantity:</label>
                                    <input type="number" name="qty" value="0" class="form-control form-control-sm" style="width:80px;" />

                                    <input type="hidden" name="eventId" value="@evt.Id" />

                                    <input type="submit" value="Buy" class="btn btn-sm btn-outline-danger" />
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>